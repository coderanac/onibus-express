{
  "openapi": "3.0.3",
  "info": {
    "title": "OniBus Express API",
    "version": "1.0.0",
    "description": "API para busca de viagens e gestão de reservas de passagens rodoviárias."
  },
  "servers": [{ "url": "/api" }],
  "tags": [
    { "name": "Rotas" },
    { "name": "Viagens" },
    { "name": "Reservas" },
    { "name": "Autenticação" }
  ],
  "paths": {
    "/rotas": {
      "get": {
        "tags": ["Rotas"],
        "summary": "Lista todas as rotas disponíveis",
        "responses": {
          "200": {
            "description": "Lista de rotas",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Route" } }
              }
            }
          }
        }
      }
    },
    "/viagens": {
      "get": {
        "tags": ["Viagens"],
        "summary": "Busca viagens por origem, destino e data",
        "parameters": [
          { "name": "origem", "in": "query", "schema": { "type": "string" } },
          { "name": "destino", "in": "query", "schema": { "type": "string" } },
          { "name": "data", "in": "query", "schema": { "type": "string", "format": "date" }, "description": "Formato AAAA-MM-DD" }
        ],
        "responses": {
          "200": {
            "description": "Viagens encontradas",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TripSearchResult" } }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/viagens/{id}": {
      "get": {
        "tags": ["Viagens"],
        "summary": "Detalhes de uma viagem, incluindo o mapa de assentos",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Detalhes da viagem",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TripSeatMap" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/reservas": {
      "post": {
        "tags": ["Reservas"],
        "summary": "Cria uma nova reserva",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateReservationInput" } }
          }
        },
        "responses": {
          "201": {
            "description": "Reserva criada",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Reservation" } } }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/reservas/{codigo}": {
      "get": {
        "tags": ["Reservas"],
        "summary": "Consulta uma reserva pelo código gerado",
        "parameters": [
          { "name": "codigo", "in": "path", "required": true, "schema": { "type": "string", "example": "ABC-12345" } }
        ],
        "responses": {
          "200": {
            "description": "Reserva encontrada",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReservationWithTrip" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Reservas"],
        "summary": "Cancela uma reserva (até 2 horas antes da partida)",
        "parameters": [
          { "name": "codigo", "in": "path", "required": true, "schema": { "type": "string", "example": "ABC-12345" } }
        ],
        "responses": {
          "200": {
            "description": "Reserva cancelada",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Reservation" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/auth/registrar": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Cria uma nova conta (nome, CPF, data de nascimento, e-mail e senha)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RegisterInput" } }
          }
        },
        "responses": {
          "201": {
            "description": "Conta criada, sessão iniciada via cookie",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Login por e-mail + senha",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/LoginInput" } }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado, sessão criada via cookie",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": {
            "description": "E-mail ou senha inválidos",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Encerra a sessão atual",
        "responses": {
          "200": { "description": "Sessão encerrada" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Autenticação"],
        "summary": "Retorna o usuário logado, se houver",
        "responses": {
          "200": {
            "description": "Usuário atual (ou null)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "user": { "$ref": "#/components/schemas/User" }, "nullable": true }
                }
              }
            }
          }
        }
      }
    },
    "/minhas-reservas": {
      "get": {
        "tags": ["Autenticação", "Reservas"],
        "summary": "Lista as reservas do usuário logado",
        "responses": {
          "200": {
            "description": "Reservas do usuário",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ReservationWithTrip" } }
              }
            }
          },
          "401": {
            "description": "Nenhuma sessão ativa",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Route": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "origin": { "type": "string" },
          "destination": { "type": "string" },
          "durationMinutes": { "type": "integer" }
        }
      },
      "Trip": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "routeId": { "type": "string" },
          "departureAt": { "type": "string", "format": "date-time" },
          "basePrice": { "type": "number" },
          "totalSeats": { "type": "integer" },
          "route": { "$ref": "#/components/schemas/Route" }
        }
      },
      "TripSearchResult": {
        "allOf": [
          { "$ref": "#/components/schemas/Trip" },
          { "type": "object", "properties": { "availableSeats": { "type": "integer" } } }
        ]
      },
      "TripSeatMap": {
        "allOf": [
          { "$ref": "#/components/schemas/Trip" },
          {
            "type": "object",
            "properties": {
              "occupiedSeats": { "type": "array", "items": { "type": "integer" } }
            }
          }
        ]
      },
      "CreateReservationInput": {
        "type": "object",
        "required": ["tripId", "seatNumber", "passengerName", "passengerCpf", "passengerEmail"],
        "properties": {
          "tripId": { "type": "string" },
          "seatNumber": { "type": "integer", "minimum": 1 },
          "passengerName": { "type": "string" },
          "passengerCpf": { "type": "string", "example": "529.982.247-25" },
          "passengerEmail": { "type": "string", "format": "email" }
        }
      },
      "Reservation": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "code": { "type": "string", "example": "ABC-12345" },
          "tripId": { "type": "string" },
          "userId": { "type": "string", "nullable": true, "description": "Preenchido quando a reserva foi criada por um usuário logado" },
          "seatNumber": { "type": "integer" },
          "passengerName": { "type": "string" },
          "passengerCpf": { "type": "string" },
          "passengerEmail": { "type": "string" },
          "status": { "type": "string", "enum": ["CONFIRMED", "CANCELLED"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "cancelledAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "ReservationWithTrip": {
        "allOf": [
          { "$ref": "#/components/schemas/Reservation" },
          { "type": "object", "properties": { "trip": { "$ref": "#/components/schemas/Trip" } } }
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "issues": { "type": "array", "items": { "type": "object" } }
        }
      },
      "LoginInput": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "maria@example.com" },
          "password": { "type": "string", "format": "password", "example": "senha1234" }
        }
      },
      "RegisterInput": {
        "type": "object",
        "required": ["name", "cpf", "birthDate", "email", "password", "confirmPassword"],
        "properties": {
          "name": { "type": "string", "example": "Maria Silva" },
          "cpf": { "type": "string", "example": "529.982.247-25" },
          "birthDate": { "type": "string", "format": "date", "example": "1990-01-01" },
          "email": { "type": "string", "format": "email", "example": "maria@example.com" },
          "password": { "type": "string", "format": "password", "example": "senha1234" },
          "confirmPassword": { "type": "string", "format": "password", "example": "senha1234" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "cpf": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "birthDate": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "responses": {
      "ValidationError": {
        "description": "Dados inválidos",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "NotFound": {
        "description": "Recurso não encontrado",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Conflict": {
        "description": "Conflito de regra de negócio (assento ocupado, prazo de cancelamento, etc.)",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    }
  }
}
